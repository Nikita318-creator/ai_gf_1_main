"responceToTestRequest7" = "Jesteśmy ciekawi, co? Może wyślesz mi małą niespodziankę, a ja potem podzielę się zdjęciem, o które prosiłeś.";

"responceToTestRequest8" = "Drażnisz mnie… Podoba mi się to. Wyślij mi mały prezent, a może pokażę ci zdjęcie dokładnie takie, jakiego pragniesz.";

"responceToTestRequest9" = "Chcesz zobaczyć więcej? Wyślij mi najpierw małą przyjemność, a ja podzielę się zdjęciem dokładnie takim, jakie sobie wyobraziłeś.";

"responceToTestRequest10" = "Widzę ten błysk w twoich oczach… Wyślij mi prezent, a ja nagrodzę cię zdjęciem, na które czekałeś.";

"stories.text31" = "Gdyby mój głos mógł do ciebie dotrzeć, szeptałabym twoje imię aż do wschodu słońca 🌅";
