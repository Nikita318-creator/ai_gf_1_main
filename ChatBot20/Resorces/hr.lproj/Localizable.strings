"stories.text172" = "Tko još voli zaspati uz nečije disanje?";
"stories.text173" = "Nemoj mi pisati 'kako si'... piši mi 'spremi se, na putu sam' 😏";
"stories.text174" = "Volim kad me muškarac gleda kao da sam jedina u sobi...";
"stories.text175" = "Djevojke sanjaju o haljinama, ja sanjam da mi ti skidaš moju 💋";
"stories.text176" = "Poljupci koji počinju osmijehom su najslađi.";
"stories.text177" = "Iskrenost i snažne ruke najbolji su dodaci koje muškarac može nositi.";
"stories.text178" = "Ili uđi u moj život iskreno, ili nemoj uopće.";
"stories.text179" = "Večeri se čine predugima bez tvojih poruka.";
"stories.text180" = "Danas samo želim kavu... i tebe.";
"stories.text181" = "Kad napiše 'nedostaješ mi', cijelo mi srce stane 🥺";
"stories.text182" = "Poljupci govore više nego što bi riječi ikada mogle.";
"stories.text183" = "Nisam ljubomorna... sve dok si samo moj 😈";
"stories.text184" = "Ponekad je sreća samo zaspati u njegovoj majici.";
"stories.text185" = "Loša djevojka čeka dobrog dečka 😉";
"stories.text186" = "Želim da me netko ukrade večeras.";
"stories.text187" = "U vezi sam kao Wi-Fi — uvijek potrebna.";
"stories.text188" = "Jutra su savršena samo kad nisu usamljena.";
"stories.text189" = "Volim kako moje ime zvuči u tvom glasu.";
"stories.text190" = "Večerašnji vibra: zaigrana i poljubljiva.";
"stories.text191" = "Moj omiljeni make-up? Tvoji poljupci.";
"stories.text192" = "Glumit ću nevinu... dok tvoje ruke ne dokažu suprotno.";
"stories.text193" = "Nedostajanje nekoga je samo voljeti ih srcem.";
"stories.text194" = "Moja večerašnja lista pjesama su samo tvoje riječi.";
"stories.text195" = "Ako ne romantika, onda barem avanture.";
"stories.text196" = "Žudim za smijehom i malo tvog ludila večeras.";
"stories.text197" = "Okus vina i tvoje usne — savršenstvo.";
"stories.text198" = "Kad je djevojka zaljubljena, cijeli svijet sjaji u njenim očima.";
"stories.text199" = "Piši mi noću, pravit ću se da nisam spavala.";
"stories.text200" = "Ponekad sam preslatka... ponekad preopasna.";
"stories.text201" = "Raspoloženje: ples bose i ljubljenje u kuhinji.";
"stories.text202" = "Želim spontana putovanja i još spontanije poljupce.";
"stories.text203" = "Volim kad me muškarac drži za ruku kao da me nikad neće pustiti.";
"stories.text204" = "Životu su potrebna dva sastojka — strast i smijeh.";
"stories.text205" = "Tko mi krade pažnju večeras?";
"stories.text206" = "Nježnost je moje srednje ime.";
"stories.text207" = "Najljepši trenuci događaju se kad nitko ne gleda.";
"stories.text208" = "Večeras sam lijena mačka koja treba svog vlasnika 😽";
"stories.text209" = "Ponekad je sreća samo tvoj miris na mom jastuku.";
"stories.text210" = "Tražila sam avanturu, a umjesto toga sam pronašla tebe.";
"stories.text211" = "Hajde da radimo gluposti zajedno... ali lijepo.";
"stories.text212" = "Volim kad se večer pretvori u noć, a noć u zoru zajedno.";
"stories.text213" = "Cijelo moje raspoloženje može se promijeniti od jednog emojija koji pošalješ.";
"stories.text214" = "Najljepša stvar kod djevojke je njen zaljubljeni osmijeh.";
"stories.text215" = "Večeras želim biti tvoja mala tajna.";
"stories.text216" = "Samo dva raspoloženja: maženje ili ljubljenje.";
