"stories.text108" = "O amor tem um gosto melhor à meia-noite 🍷";
"stories.text109" = "Batom vermelho, pensamentos selvagens 💄🔥";
"stories.text110" = "Corações brincalhões nunca envelhecem 🎠";
"stories.text111" = "Domingos são para abraços 🛌💕";
"stories.text112" = "Nem todo mundo merece lugares na primeira fila da sua vida 🎟️";
"stories.text113" = "Toda cicatriz conta uma história bonita 🌹";
"stories.text114" = "Olhos que flertam sem tentar 👁️‍🗨️";
"stories.text115" = "Coque bagunçado, diversão perigosa 😏";
"stories.text116" = "Noites chuvosas e beijos roubados ☔💋";
"stories.text117" = "Sem drama, mas um pouco misteriosa 🔮";
"stories.text118" = "Algumas noites pedem champanhe 🥂";
"stories.text119" = "Minha playlist conhece meus segredos 🎶";
"stories.text120" = "Doce o suficiente para derreter sua guarda 🍫";
"stories.text121" = "Roubar corações é meu exercício ❤️‍🔥";
"stories.text122" = "Aviso: fofa demais para aguentar 😉";
"stories.text123" = "Borboletas? Mais como fogos de artifício 🎆";
"stories.text124" = "Às vezes doce, às vezes selvagem 😏";
"stories.text125" = "Humor: batom e confiança 💄";
"stories.text126" = "Um pouco de mistério nunca fez mal 🔮";
"stories.text127" = "Eu gosto do meu café como das minhas noites… longas e quentes ☕🌙";
"stories.text128" = "Perigosa na discrição, adorável na essência 😇🔥";
"stories.text129" = "Sorrisos são minha arma secreta 😉";
"stories.text130" = "Cartas de amor nos meus rascunhos 💌";
"stories.text131" = "Não me tente… ou me tente 😏";
"stories.text132" = "Coração macio, mente afiada ✨";
"stories.text133" = "Meio doce, meio tóxica 🥂";
"stories.text134" = "Olhos de problema, lábios de pecado 💋";
"stories.text135" = "Não perdida, apenas vagando 🌸";
"stories.text136" = "Romance me cai bem 🌹";
"stories.text137" = "Opa… acabei de roubar seu humor? 😌";
"stories.text138" = "Mistura perfeita de caos e charme 🎭";
"stories.text139" = "O amor tem um gosto melhor depois da meia-noite 🌌";
"stories.text140" = "Pensamentos selvagens, sorriso calmo 😏";
"stories.text141" = "Acreditando em sonhos, roubando corações 💫";
"stories.text142" = "Cabelo bagunçado, não me importo 💕";
"stories.text143" = "Doçura sobrecarregada 🍓";
"stories.text144" = "Desejos de madrugada não são só por comida 🥂";
"stories.text145" = "Querido, eu sou minha própria musa 🎨";
"stories.text146" = "Problemas nunca foram tão macios 💞";
"stories.text147" = "Olhos fechados, lábios entreabertos… opa 😳";
"stories.text148" = "Mel misturado com veneno 🍯💀";
"stories.text149" = "Sorrisos de lado são subestimados 😉";
"stories.text150" = "Caos romântico é a minha vibe 💌";
"stories.text151" = "Fofa, mas tramando algo 😈";
"stories.text152" = "Moletons roubados, corações roubados 🧥💕";
"stories.text153" = "Falhas? Mais como características ✨";
"stories.text154" = "Corações não vêm com instruções ❤️";
"stories.text155" = "Opa, brilhei de novo ✨😉";
"stories.text156" = "Esta noite parece um segredo 🌙";
"stories.text157" = "Eu visto a confiança melhor que perfume 🌸";
"stories.text158" = "Mordidas de amor duram mais que batom 💄";
"stories.text159" = "Lábios macios, difíceis de resistir 💋";
"stories.text160" = "Luz de velas esconde todos os pecados 🕯️";
"stories.text161" = "Beijada pelo sol e aprovada para a bagunça ☀️😏";
"stories.text162" = "Um pouco de açúcar, um pouco de pimenta 🍭🌶️";
"stories.text163" = "Corações batem mais rápido à meia-noite 🖤";
"stories.text164" = "Eu brilho mais depois de escurecer 🌌";
"stories.text165" = "Um caos gentil parece um lar 🌪️";
"stories.text166" = "Sonhando em voz alta esta noite 🌙";
"stories.text167" = "Olhares de flerte, iscas perigosas 😉";
"stories.text168" = "Eu coleciono sorrisos como tesouros 💎";
"stories.text169" = "Abraços são a minha linguagem do amor 🛌💕";
"stories.text170" = "Corações selvagens não podem ser domados 🐆";
"stories.text171" = "À noite, eu só quero abraçar alguém e ficar em silêncio 🖤";
"stories.text172" = "Quem mais ama adormecer ouvindo a respiração de alguém?";
"stories.text173" = "Não me mande 'como você está'... me mande 'se prepare, estou a caminho' 😏";
"stories.text174" = "Eu amo quando um homem me olha como se eu fosse a única na sala…";
"stories.text175" = "Garotas sonham com vestidos, eu sonho em você tirando o meu 💋";
"stories.text176" = "Beijos que começam com um sorriso são os mais doces.";
"stories.text177" = "Honestidade e braços fortes são os melhores acessórios que um homem pode usar.";
"stories.text178" = "Ou você entra na minha vida para valer, ou não entra de jeito nenhum.";
"stories.text179" = "As noites parecem longas demais sem as suas mensagens.";
"stories.text180" = "Hoje eu só quero café… e você.";
"stories.text181" = "Quando ele escreve 'estou com saudades', meu coração inteiro para 🥺";
"stories.text182" = "Beijos dizem mais do que palavras jamais poderiam.";
"stories.text183" = "Não sou ciumenta… contanto que você seja só meu 😈";
"stories.text184" = "Às vezes a felicidade é apenas adormecer com a camiseta dele.";
"stories.text185" = "Uma garota má esperando por um garoto bom 😉";
"stories.text186" = "Eu quero que alguém me leve embora esta noite.";
"stories.text187" = "Em um relacionamento, sou como o Wi-Fi — sempre necessária.";
"stories.text188" = "As manhãs são perfeitas apenas quando não são solitárias.";
"stories.text189" = "Eu amo como meu nome soa na sua voz.";
"stories.text190" = "A vibe de hoje à noite: brincalhona e beijável.";
"stories.text191" = "Minha maquiagem favorita? Seus beijos.";
"stories.text192" = "Vou agir como inocente… até que suas mãos provem o contrário.";
"stories.text193" = "Sentir falta de alguém é simplesmente amá-lo com o seu coração.";
"stories.text194" = "Minha playlist de hoje à noite são apenas suas palavras.";
"stories.text195" = "Se não for romance, que sejam aventuras.";
"stories.text196" = "Eu desejo risadas e um pouco da sua loucura esta noite.";
"stories.text197" = "O sabor do vinho e dos seus lábios — perfeição.";
"stories.text198" = "Quando uma garota está apaixonada, o mundo inteiro brilha em seus olhos.";
"stories.text199" = "Me mande mensagem à noite, vou fingir que não estava dormindo.";
"stories.text200" = "Às vezes sou doce demais... às vezes perigosa demais.";
